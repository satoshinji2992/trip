# Flask
FLASK_ENV=development
SECRET_KEY=trip-system-secret-key-2024
# DATABASE_URL不填时默认使用 backend/trip.db
# DATABASE_URL=sqlite:////绝对路径/trip.db

# AIGC旅游动画生成：OpenAI-compatible / Wan兼容接口
AIGC_API_KEY=填你的API_KEY
AIGC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AIGC_MODEL=wan2.1-i2v-turbo
AIGC_ENDPOINT=/videos/generations
